{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "entry": [
    ".pokayoke/rules/**/*.rule.ts",
    "apps/docs/pages/**/*.tsx",
    "apps/docs/vite.config.ts",
    "packages/pokayoke/src/cli.ts",
    "packages/pokayoke/src/index.ts"
  ],
  "project": [".pokayoke/**/*.ts", "apps/docs/**/*.ts", "apps/docs/**/*.tsx", "packages/**/*.ts"],
  "ignoreFiles": ["apps/docs/**/*.test.ts", "packages/**/*.test.ts"],
  "treatConfigHintsAsErrors": true,
  "treatTagHintsAsErrors": true
}
